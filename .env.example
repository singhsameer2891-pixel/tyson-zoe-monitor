# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here  # For groups, use the negative supergroup ID (e.g. -1003764007243)

# Notification
NOTIFICATION_COOLDOWN_SECONDS=60

# Frigate
FRIGATE_API_URL=http://frigate:5000

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883

# API
API_PORT=4000

# Remote Diagnostics (GitHub Gist — auto-updated every 1 min)
GITHUB_GIST_TOKEN=your_github_gist_token_here

# Dashboard
VITE_API_URL=http://localhost:4000
# Host machine IP — used for Frigate iframe URL in dashboard (set to your machine's LAN IP)
HOST_IP=localhost
